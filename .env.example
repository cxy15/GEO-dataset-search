# ---------- NCBI E-utilities（GEO 使用 db=gds）----------
# 政策要求的联系邮箱（用于标识调用方，不是登录密码）
ENTREZ_EMAIL=

# 可选：NCBI 账号申请的 API Key，请求会带 api_key=…，提高速率等
# https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# ---------- LLM：任意 OpenAI 兼容 HTTP 服务 ----------
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
